# Copiar a ".env" en esta misma carpeta y completar con valores reales.
# El archivo ".env" está en .gitignore — nunca comitear secretos reales.

# ── Base de datos ──────────────────────────────────────────────
POSTGRES_DB=gestortareasdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIAR_por_una_contrasena_segura

# ── Seguridad ──────────────────────────────────────────────────
# Generar con: openssl rand -base64 64
APP_JWT_SECRET=CAMBIAR_generar_con_openssl_rand_base64_64
# Dominio real del frontend, sin barra final. Separar con coma si hay más de uno.
APP_CORS_ALLOWED_ORIGINS=https://tu-dominio.com

# ── SMTP (envío del digest de novedades) ────────────────────────
# Cualquier proveedor SMTP real: Gmail (con contraseña de aplicación), SendGrid, Mailgun, SES, etc.
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USERNAME=CAMBIAR
SMTP_PASSWORD=CAMBIAR
MAIL_FROM=notificaciones@tu-dominio.com

# Horarios del digest (formato cron de Spring). Opcional, ya traen estos defaults.
# DIGEST_CRON_MEDIODIA=0 0 12 * * *
# DIGEST_CRON_NOCHE=0 0 19 * * *

# Horas que se cachea la membresía de un usuario a un tablero. Opcional, default 6.
# MEMBRESIA_TABLERO_CACHE_TTL_HORAS=6

# ── Imágenes (opcional) ──────────────────────────────────────────
# Si taggean versiones en vez de usar "latest":
# API_TAG=1.2.0
# WEB_TAG=1.2.0

# ── Certificados (no son variables de entorno, es un recordatorio) ──
# Colocar en ./certs/ (mismo directorio que este .env):
#   cloudflare-origin.pem   <- Origin Certificate (Cloudflare Dashboard > SSL/TLS > Origin Server)
#   cloudflare-origin.key   <- su clave privada
# Configurar en Cloudflare: SSL/TLS > Overview > modo "Full (strict)"
